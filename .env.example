# ─────────────────────────────────────────────────────────────
# White Rabbit Productions — environment variables
# Copy to .env.local for development. All are OPTIONAL: the site
# builds and runs without them, using graceful fallbacks.
# ─────────────────────────────────────────────────────────────

# Public site URL (used for metadata, canonical URLs, sitemap, robots).
NEXT_PUBLIC_SITE_URL=https://whiterabbitproductions.com

# ── Email delivery (Resend) ──
# Required together for booking/contact forms to send email.
# Without these, submissions are accepted and logged to the server
# console, and forms show a graceful, non-blocking message.
RESEND_API_KEY=
INQUIRY_TO_EMAIL=
INQUIRY_FROM_EMAIL=

# ── Public contact details (shown on the site) ──
NEXT_PUBLIC_CONTACT_EMAIL=hello@whiterabbitproductions.com
NEXT_PUBLIC_INSTAGRAM_URL=

# ── Scheduling (Cal.com) ──
# A full URL (https://cal.com/your-handle) or just "your-handle".
# When empty, the Book page shows fallback scheduling messaging.
NEXT_PUBLIC_CAL_LINK=

# ── Optional future integrations (not required to build) ──
# Shopify storefront (Shop page)
NEXT_PUBLIC_SHOPIFY_STORE_DOMAIN=
NEXT_PUBLIC_SHOPIFY_STOREFRONT_TOKEN=

# Sanity CMS (portfolio/shop content)
NEXT_PUBLIC_SANITY_PROJECT_ID=
NEXT_PUBLIC_SANITY_DATASET=production

# Supabase (optional lead storage)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
